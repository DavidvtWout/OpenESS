{
  "name": "open-ess-frontend",
  "private": true,
  "scripts": {
    "build": "esbuild open_ess/frontend/src/*.ts --outdir=open_ess/frontend/static --bundle --minify --sourcemap",
    "watch": "esbuild open_ess/frontend/src/*.ts --outdir=open_ess/frontend/static --bundle --sourcemap --watch",
    "generate-types": "openapi-typescript http://localhost:8000/openapi.json -o open_ess/frontend/src/api-types.ts"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.4.0"
  }
}
